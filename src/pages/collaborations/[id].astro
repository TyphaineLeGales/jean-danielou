---
import type { GetStaticPaths } from "astro";
import Layout from '../../layouts/Layout.astro';
import { slugify } from '../../utils/slugify.js';
import { getCollection } from 'astro:content';
export const getStaticPaths = (async() => {
    const collaborations = await getCollection('collaborations')
    const sorted = collaborations.filter(a => a.id.includes("fr/"))
    return sorted.map(collab => {
        return {
            params: {id: slugify(collab.id.replace('fr/', ''))},
            props: {collab}
        }

    });
}) satisfies GetStaticPaths;
import CollaborationsDetails from '../../components/collaboration/Details.astro'
const {collab} = Astro.props
---
<Layout>
    <CollaborationsDetails collaboration={collab}/>
</Layout>
