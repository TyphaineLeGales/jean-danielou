---
import Layout from '../layouts/Layout.astro';
import Book from '../components/Book.astro'
import { getCollection } from 'astro:content';
const books = await getCollection('books_fr')
---
<Layout>
    <h1 class="my-24 text-5xl font-semibold uppercase font-lexend page-header">Books</h1>
    <ul class="md:w-3/4 md:pl-20">
        {books.map(book => 
        <li class="my-6">
            <Book data={book.data} description={book.body}/> 
        </li>)}
    </ul>
</Layout>