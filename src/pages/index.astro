---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import SelectedWork from '../components/SelectedWork.astro';
import { marked } from "marked";
import { getCollection } from 'astro:content';
const landing = await getCollection('landing');
const content = marked.parse(landing.filter(b => b.id.startsWith('fr/'))[0].data.text);
---

<Layout>
	<About content={content} lang="fr"/>
	<SelectedWork lang="fr"/>
</Layout>
