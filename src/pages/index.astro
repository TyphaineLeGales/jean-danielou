---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import compo1 from '../assets/INCOPR_compo_1_test.png';
import Intro from '../components/UI/Intro.astro';

import IconArrow from '../components/UI/IconArrow.vue'
import ListItem from '../components/ListItem.vue';
import {recentWork }from '../config/dummyData'
import {index} from '../config/UI'
import { getCollection } from 'astro:content';
const landing = await getCollection('landing_fr')

const currentPath = Astro.url.pathname;
const isEnglish = currentPath.startsWith('/en');
const lang = isEnglish ? "en" : "fr"
---

<Layout>
	<Intro />
	<div class="fixed hidden opacity-75 pointer-events-none size-full md:block -z-10 -translate-y-1/6" style={`background-image:url(${compo1.src});background-size:contain;background-repeat:no-repeat`}></div>
	<Image class="w-auto h-auto -translate-x-2 opacity-75 md:hidden" src={compo1} alt="Abstract drawing of flux" />
	<div class="w-full md:w-[calc(100%-var(--spacing)*10)] flex flex-col items-center">
		<h1 class="text-3xl bg-white md:text-5xl font-balthazar md:mt-36 leading-12 xl:leading-16 "> 
			{index[`title_${lang}`].map((item) => (
			item.highlight ? (
				<span class="text-2xl font-lexend md:text-4xl">
				{item.text}
				</span>
			) : (
				item.text
			)
			))}
		</h1>
		<p class="mt-12 whitespace-pre-line bg-white md:w-1/3">
			{landing.map(e => e.data.text) }
		</p>
	</div>
	<div class="bottom-0 w-full p-4 mt-4 md:absolute">
		<span class="flex items-center justify-start"> <IconArrow class="scale-75"/> <h2 class="text-xl font-medium text-left text-gray-800 font-lexend">Recent work</h2></span>
		<ul class="w-full">
			{recentWork.map(e =><li class="px-2 bg-white border-b md:px-4 first:border-t">
				<span class="flex justify-between w-full text-xs md:text-sm"><p class="font-light uppercase font-lexend">{e.type}</p><p class="pr-4 text-right">{e.year}</p></span>
				<ListItem text={e.title} client:visible/>
			</li>)}
		</ul>
	</div>
</Layout>

