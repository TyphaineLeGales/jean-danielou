---
import type { GetStaticPaths } from "astro";
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import BookDetails from '../../components/book/Details.astro';
import { slugify } from '../../utils/slugify.js';

export const getStaticPaths = (async () => {
    const books = await getCollection('books');
    const frBooks = books.filter(b => b.id.startsWith('fr/'));

    return frBooks.map(book => ({
        params: { id: slugify(book.id.replace('fr/', '')) },
        props: { book }
    }));
}) satisfies GetStaticPaths;

const { book } = Astro.props;
const metaTitle = "Jean Daniélou - " + book.data.title
---
<Layout description={book.data.lead} image={book.data.thumbnail} title={metaTitle} >
    <BookDetails book={book} />
</Layout>