---
import Layout from '../../layouts/Layout.astro';
import BookList from '../../components/book/List.astro'
import { slugify } from '../../utils/slugify.js';
import { getCollection } from 'astro:content';
const books = await getCollection('books')
const sortedBooks = books
  .filter(b => b.id.startsWith('fr/'))
  .sort((a, b) => Number(b.data.date) - Number(a.data.date));

const slugNames = sortedBooks.map(book => slugify(book.id.slice(3)))
---
<Layout>
    <h1 class="my-24 text-3xl font-semibold uppercase md:text-5xl font-lexend page-header">
        Livres
    </h1>
    <ul class=" md:px-20">
        {sortedBooks.map((book, i) => 
        <li class="my-6">
            <BookList data={book.data} description={book.body} id={slugNames[i]}/> 
        </li>)}
    </ul>
</Layout>