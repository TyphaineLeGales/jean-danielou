---
import type { GetStaticPaths } from "astro";
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import BookDetails from '../../../components/book/Details.astro';
import { enrichBookWithFrData } from '../../../utils/fullBookInfo';
import { slugify } from '../../../utils/slugify.js';

export const getStaticPaths = (async () => {
    const books = await getCollection('books');
    const enBooks = books.filter(b => b.id.startsWith('en/'));
    return enBooks.map(book => ({
        params: { id: slugify(book.id.replace('en/', '')) },
        props: { book }
    }));
}) satisfies GetStaticPaths;

const { book } = Astro.props;
const enrichedBook = await enrichBookWithFrData(book);
const metaTitle = "Jean Daniélou - " + book.data.title
---
<Layout description={book.data.lead} image={book.data.thumbnail} title={metaTitle}>
    <BookDetails book={enrichedBook}/>
</Layout>
