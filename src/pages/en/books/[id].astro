---
import type { GetStaticPaths } from "astro";
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import BookDetails from '../../../components/book/Details.astro';
import { enrichBookWithFrData } from '../../../utils/fullBookInfo';

export const getStaticPaths = (async () => {
    const books = await getCollection('books');
    const enBooks = books.filter(b => b.id.startsWith('en/'));
    return enBooks.map(book => ({
        params: { id: book.id.replace('en/', '').normalize('NFC') },
        props: { book }
    }));
}) satisfies GetStaticPaths;

const { book } = Astro.props;
const enrichedBook = await enrichBookWithFrData(book);
---
<Layout>
    <BookDetails book={enrichedBook}/>
</Layout>
