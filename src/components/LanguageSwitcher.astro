---
const currentPath = Astro.url.pathname;
const isEnglish = currentPath.startsWith('/en');

let frPath = currentPath;
let enPath = currentPath;

if (!isEnglish) {
  enPath = `/en${currentPath === '/' ? '' : currentPath}`;
}

if (isEnglish) {
  frPath = currentPath.replace(/^\/en/, '') || '/';
}
---

<nav class="language-switcher">
  <a href={frPath} aria-current={!isEnglish ? 'page' : undefined} >
    FR
  </a>

  <span>|</span>

  <a href={enPath} aria-current={isEnglish ? 'page' : undefined}>
    EN
  </a>
</nav>

<style>
.language-switcher {
  display: flex;
  gap: 0.5rem;
}

.language-switcher a {
  opacity: 0.6;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

.language-switcher a[aria-current="page"] {
  opacity: 1;
  text-decoration: underline !important;
}
</style>