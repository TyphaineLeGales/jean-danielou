---
const currentPath = Astro.url.pathname;

/*
Examples:

/                -> fr
/about           -> fr
/en              -> en
/en/about        -> en
*/

const isEnglish = currentPath.startsWith('/en');

let frPath = currentPath;
let enPath = currentPath;

// Convert to EN
if (!isEnglish) {
  enPath = `/en${currentPath === '/' ? '' : currentPath}`;
}

// Convert to FR
if (isEnglish) {
  frPath = currentPath.replace(/^\/en/, '') || '/';
}
---

<nav class="language-switcher">
  <a href={frPath} aria-current={!isEnglish ? 'page' : undefined}>
    FR
  </a>

  <span>|</span>

  <a href={enPath} aria-current={isEnglish ? 'page' : undefined}>
    EN
  </a>
</nav>

<style>
.language-switcher {
  display: flex;
  gap: 0.5rem;
}
</style>