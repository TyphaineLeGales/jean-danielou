---
import { routes } from '../config/navRoutes'
import MobileMenuIsland from './MobileMenuIsland.vue'
import "../styles/global.css";
---
<nav class="fixed top-0 z-50 flex justify-between w-full p-2 bg-white border-b md:p-4">
  <div class="flex-1 text-xl font-balthazar">
    <a href="/">Jean Daniélou</a>
  </div>
  <ul class="justify-between flex-1 hidden font-lexend md:flex">
    {routes.map(route => (
      <li><a href={route.path}>{route.name}</a></li>
    ))}
  </ul>
  <MobileMenuIsland client:media="(max-width: 768px)" class="md:hidden"/>
</nav>