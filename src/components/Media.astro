---
const { data } = Astro.props;
---

<div class="flex pt-12 pb-6 my-3 border-b-1">
    <a class="md:pl-6" href={data.link} target="_blank">
        <h1 class="mb-2 text-2xl underline md:w-2/3 md:text-4xl font-balthazar">{data.title}</h1>
        <div class="flex">
            <p class="flex-1"> Publié sur <span class="font-bold">{data.publishedon}</span> le {data.date}</p>
            <p class="p-6 flex-2">{data.text}</p>
        </div>
    </a>
</div>