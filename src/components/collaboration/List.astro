---
const { data, description, id, lang } = Astro.props;
import {marked} from "marked"
const text = marked.parse(description)
const href = lang === 'en' ? `/en/collaborations/${id}` : `/collaborations/${id}`;
---

<a href={href} class="flex flex-col mb-12 md:flex-row md:px-20">
    <div class="flex justify-center mb-4 ">
        <div class="flex items-center justify-center w-1/2 overflow-hidden border bg-toxic-green">
            <img
                src={data.thumbnail}
                class="w-auto h-full"
            />
        </div>
    </div>

    <div class="flex-2 md:pl-6">
        <p class="md:mb-3">{data.date}</p>
        <h1 class="text-3xl underline font-balthazar">
            {data.title} x {data.collaborators.map(c => c.name)}
        </h1>
        <div class="p-6">
            <Fragment set:html={text}/>
        </div>
    </div>
</a>