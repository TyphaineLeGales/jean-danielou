---
const { data, description, id } = Astro.props;
---

<a href={`/collaborations/${id}`} class="flex flex-col mb-12 md:flex-row md:px-20">
    <div class="flex justify-center mb-4">
        <div class="flex items-center justify-center w-64 h-64 overflow-hidden border bg-toxic-green">
            <img
                src={data.thumbnail}
                class="w-auto h-full"
            />
        </div>
    </div>

    <div class="md:pl-6 flex-2">
        <p class="md:mb-3">{data.date}</p>
        <h1 class="text-3xl underline font-balthazar">
            {data.title}
        </h1>
        <p class="p-6">{description}</p>
    </div>
</a>