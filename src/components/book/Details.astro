---
import Quit from '../../components/UI/Quit.astro'
const {book} = Astro.props
---
<div class="flex py-4 border-b">
        <a href="/books"><Quit/></a>
        <h1 class="text-3xl font-balthazar">{book.data.title} </h1>
        <p>{book.data.date}</p>
    </div>
   
    <slot />
    <div class="flex flex-col md:flex-row">
        <div class="flex-1">
            <div>
                <img src={book.data.thumbnail}/>
                {book.data.images?.map(i => <img src={i.image}/>)}
            </div>
        </div>
        <div class="flex-1">
            <p class="mb-4 font-bold">{book.data.lead}</p>
            <p>{book.body}</p>
            <ul class="mt-4">
                {book.data.reviews?.map(r => (
                    <li class="mb-4 bullet-point"> 
                        <a href={r.link} target="_blank">
                            <p>
                                <span class="text-sm font-light">{r.date}</span>
                                <span class="text-sm font-bold">{r.published}</span>
                                <span class="text-sm font-light">{r.author}</span>

                            </p>
                            <p class="text-lg leading-5 underline font-balthazar">{r.title}</p>
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    </div>